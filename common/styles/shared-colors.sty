\ProvidesPackage{shared-colors}
\RequirePackage{xcolor}

%************************************************************
% Shared Color Definitions
% Used by both presentation and document themes
%************************************************************

%************************************************************
% University of Twin Stars Theme Colors
% Inspired by Cradle series: Lindon's madra (blue/black) + Yerin's madra (crimson/silver)
%************************************************************
\definecolor{TwinStarsBlue}{RGB}{20,35,110}          % Deep blue (Lindon's color)
\definecolor{TwinStarsCrimson}{RGB}{160,20,35}       % Deep crimson (Yerin's color)
\definecolor{TwinStarsSilver}{RGB}{185,192,200}      % Silver/white tone
\definecolor{TwinStarsGold}{RGB}{220,175,50}         % Gold accent

%************************************************************
% ACME Corp Theme Colors
% Professional corporate palette: dark, modern, accessible
%************************************************************
\definecolor{AcmeCharcoal}{RGB}{45,48,55}            % Deep charcoal (primary dark)
\definecolor{AcmeRed}{RGB}{195,30,35}                % Corporate red (accent)
\definecolor{AcmeGray}{RGB}{120,125,135}             % Supporting gray
\definecolor{AcmeOffWhite}{RGB}{245,245,247}         % Off-white background

%************************************************************
% Utility Colors
%************************************************************
\definecolor{Black}{RGB}{0,0,0}
\definecolor{White}{RGB}{255,255,255}
\definecolor{LightGray}{RGB}{220,220,220}
\definecolor{DarkGray}{RGB}{80,80,80}

%************************************************************
% Notes:
% - All color definitions are in RGB for better compatibility
% - Aim for WCAG AA contrast ratios (4.5:1 for text)
% - Consider colorblind-friendly palettes
% - Both themes use distinct visual languages:
%   * Twin Stars: academic, warm (blue+crimson+gold)
%   * ACME Corp: corporate, cool (charcoal+red, minimal)
%************************************************************
