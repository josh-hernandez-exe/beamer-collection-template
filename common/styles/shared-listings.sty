%************************************************************
% Extensibility: How to add a new language
%************************************************************
% To add support for a language not listed above:
%
% \lstdefinelanguage{MyLanguage}{
%     keywords={keyword1,keyword2,keyword3},
%     keywordstyle=\color{DeepBlue}\bfseries,
%     commentstyle=\color{CommentDarkGreen}\ttm,
%     stringstyle=\color{DeepGreen},
%     basicstyle=\ttm\small,
%     frame=tb,
%     showstringspaces=false,
%     breaklines=true,
%     sensitive=true
% }
%
% Then define a style:
% \lstdefinestyle{mylanguagestyle}{
%     language=MyLanguage,
%     ... (inherit from defaults above)
% }
%
% Use in your document:
% \begin{lstlisting}[style=mylanguagestyle]
% ... your code here ...
% \end{lstlisting}
