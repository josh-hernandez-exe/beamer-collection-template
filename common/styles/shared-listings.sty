\ProvidesPackage{shared-listings}
\RequirePackage[usenames,dvipsnames,dvisvgm]{xcolor}

%************************************************************
% Code Inclusion Configuration
%************************************************************
\usepackage{listings}
\usepackage{courier}

%************************************************************
% Color Definitions for Syntax Highlighting
%************************************************************
\definecolor{CommentDarkGreen}{rgb}{0.0,0.4,0.0}
\definecolor{DeepBlue}{rgb}{0,0,0.5}
\definecolor{DeepRed}{rgb}{0.6,0,0}
\definecolor{DeepGreen}{rgb}{0,0.5,0}
\definecolor{StringBrown}{rgb}{0.6,0.3,0}

\lstloadlanguages{Python,Java}

% Default fixed font does not support bold face
\newcommand{\ttb}{\fontfamily{txtt}\fontseries{bx}\selectfont}
\newcommand{\ttm}{\fontfamily{txtt}\fontseries{m}\selectfont}

%************************************************************
% Python Style
%************************************************************
\lstdefinestyle{pythonstyle}{
    language=Python,
    basicstyle=\ttm\small,
    otherkeywords={self},
    keywordstyle=\ttm\color{DeepBlue},
    emph={MyClass,__init__},
    emphstyle=\ttb\color{DeepRed},
    stringstyle=\color{DeepGreen},
    commentstyle=\color{CommentDarkGreen}\ttm,
    frame=tb,
    showstringspaces=false,
    breaklines=true,
}

%************************************************************
% Java Style
%************************************************************
\lstdefinestyle{javastyle}{
    language=Java,
    basicstyle=\ttm\small,
    otherkeywords={self},
    keywordstyle=\ttm\color{DeepBlue},
    emph={MyClass,__init__},
    emphstyle=\ttb\color{DeepRed},
    stringstyle=\color{DeepGreen},
    commentstyle=\color{CommentDarkGreen}\ttm,
    frame=tb,
    showstringspaces=false,
    breaklines=true,
}

